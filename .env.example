# Ouroboros local secrets template.
# Copy to .env.local, fill values, then load with:
#   set -a; source .env.local; set +a

# Hugging Face Hub: read/write access to WeirdRunner/Ouroboros.
HF_TOKEN=
HUGGINGFACE_HUB_TOKEN=

# GitHub: repo access for deveshpat/Ouroboros signals and workflow/runtime checkout.
GH_TOKEN=
GITHUB_TOKEN=

# Weights & Biases.
WANDB_KEY=
WANDB_API_KEY=
OUROBOROS_WANDB_PROJECT=ouroboros-stage3-jamba
OUROBOROS_WANDB_ENTITY=

# Kaggle worker accounts.
KAGGLE_USERNAME_A=
KAGGLE_KEY_A=
KAGGLE_USERNAME_B=
KAGGLE_KEY_B=
KAGGLE_USERNAME_C=
KAGGLE_KEY_C=

# Local/current worker identity, only needed when running one worker directly.
DILOCO_WORKER_ID=
OUROBOROS_DILOCO_WORKER_ID=
WORKER_ID=

# Hub/GitHub repo routing.
OUROBOROS_DILOCO_STATE_REPO=WeirdRunner/Ouroboros
OUROBOROS_DILOCO_SIGNAL_REPO=deveshpat/Ouroboros
OUROBOROS_REPO_URL=https://github.com/deveshpat/Ouroboros.git
OUROBOROS_REPO_REF=mac-dgac-fallback
OUROBOROS_REPO_COMMIT=

# Launch mode controls.
OUROBOROS_KAGGLE_RUN_MODE=dgac-canary
OUROBOROS_DILOCO_OUTER_LR=0.7
OUROBOROS_DILOCO_OUTPUT_DIR=runs/diloco
OUROBOROS_DGAC_ANCHOR_EVAL_OUTPUT_DIR=runs/dgac_anchor_eval
OUROBOROS_DGAC_OUTPUT_DIR=runs/stage3_dgac
OUROBOROS_DGAC_CANARY_OUTPUT_DIR=runs/stage3_dgac_canary
OUROBOROS_DGAC_DILOCO_OUTPUT_DIR=runs/dgac_dedicated

# lm-evaluation-harness benchmark controls.
OUROBOROS_BENCHMARK_TASKS=arc_easy,hellaswag,winogrande
OUROBOROS_BENCHMARK_LIMIT=100
OUROBOROS_BENCHMARK_OUTPUT_DIR=runs/lm_eval_benchmark
OUROBOROS_BENCHMARK_BASE_MODEL=ai21labs/AI21-Jamba-Reasoning-3B
OUROBOROS_BENCHMARK_ADAPTER_REPO=WeirdRunner/Ouroboros
OUROBOROS_BENCHMARK_ADAPTER_SUBFOLDER=diloco_state/anchor
OUROBOROS_BENCHMARK_BATCH_SIZE=1
OUROBOROS_BENCHMARK_DEVICE=cuda:0
OUROBOROS_BENCHMARK_DTYPE=float16
OUROBOROS_BENCHMARK_MODEL_ARGS=
OUROBOROS_BENCHMARK_PUBLISH_TO_HUB=1
OUROBOROS_BENCHMARK_SANITIZE_VOCAB_MISMATCH=1

# Ouroboros inference smoke controls.
OUROBOROS_INFERENCE_PROMPT=Explain the core idea briefly.
OUROBOROS_INFERENCE_BASE_MODEL=ai21labs/AI21-Jamba-Reasoning-3B
OUROBOROS_INFERENCE_ADAPTER_REPO=WeirdRunner/Ouroboros
OUROBOROS_INFERENCE_ADAPTER_SUBFOLDER=diloco_state/anchor
OUROBOROS_INFERENCE_ADAPTER_DIR=
OUROBOROS_INFERENCE_STAGE_K=10
OUROBOROS_INFERENCE_MAX_NEW_TOKENS=128
OUROBOROS_INFERENCE_MAX_SEQ_LEN=512
OUROBOROS_INFERENCE_USE_HALT_GATE=1
OUROBOROS_INFERENCE_DEVICE=auto
OUROBOROS_INFERENCE_DTYPE=auto

# CPU-smoke validation controls.
OUROBOROS_WORKFLOW_VALIDATE=
OUROBOROS_WORKFLOW_VALIDATION_RUN_ID=
OUROBOROS_WORKFLOW_VALIDATION_PUBLISH=
OUROBOROS_WORKFLOW_VALIDATION_STATE_REPO=WeirdRunner/Ouroboros
OUROBOROS_VALIDATION_STAGE_K=10
OUROBOROS_VALIDATION_ROUND_N=0

# Strict local Mac DGAC fallback.
OUROBOROS_MAC_DGAC_CLAIM_ID=
PYTORCH_ENABLE_MPS_FALLBACK=1
